@prefix : <http://www.semanticweb.org/laurasla/ontologies/2025/1/untitled-ontology-134/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pko: <https://w3id.org/pko#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcam: <http://purl.org/dc/dcam/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix bedreflyt: <http://www.smolang.org/bedreflyt/> .
@base <http://www.semanticweb.org/laurasla/ontologies/2025/1/untitled-ontology-134/> .

<http://www.smolang.org/bedreflyt/> rdf:type owl:Ontology ;
                                     owl:versionIRI <http://www.smolang.org/bedreflyt/2.0.1> ;
                                     rdfs:comment "An ontology to model the structure of hospitals, including wards, floors, and rooms." ,
                                                  "Knowledge about treatment workflows, objects relevant to the workflow such as beds, personnel types involved in the workflow." ;
                                     rdfs:label "Hospital Ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000179
obo:BFO_0000179 rdf:type owl:AnnotationProperty ;
                rdfs:label "BFO OWL specification label"@en .


###  http://purl.obolibrary.org/obo/BFO_0000180
obo:BFO_0000180 rdf:type owl:AnnotationProperty ;
                rdfs:label "BFO CLIF specification label"@en .


###  http://purl.obolibrary.org/obo/IAO_0000112
obo:IAO_0000112 rdf:type owl:AnnotationProperty ;
                rdfs:label "example of usage"@en .


###  http://purl.obolibrary.org/obo/IAO_0000115
obo:IAO_0000115 rdf:type owl:AnnotationProperty ;
                rdfs:label "definition"@en .


###  http://purl.obolibrary.org/obo/IAO_0000116
obo:IAO_0000116 rdf:type owl:AnnotationProperty ;
                rdfs:label "editor note"@en .


###  http://purl.obolibrary.org/obo/IAO_0000117
obo:IAO_0000117 rdf:type owl:AnnotationProperty ;
                rdfs:label "term editor"@en .


###  http://purl.obolibrary.org/obo/IAO_0000119
obo:IAO_0000119 rdf:type owl:AnnotationProperty ;
                rdfs:label "definition source"@en .


###  http://purl.obolibrary.org/obo/IAO_0000232
obo:IAO_0000232 rdf:type owl:AnnotationProperty ;
                rdfs:label "curator note"@en .


###  http://purl.obolibrary.org/obo/IAO_0000412
obo:IAO_0000412 rdf:type owl:AnnotationProperty ;
                rdfs:label "imported from"@en .


###  http://purl.obolibrary.org/obo/IAO_0000601
obo:IAO_0000601 rdf:type owl:AnnotationProperty ;
                rdfs:label "has associated axiom(nl)"@en .


###  http://purl.obolibrary.org/obo/IAO_0000602
obo:IAO_0000602 rdf:type owl:AnnotationProperty ;
                rdfs:label "has associated axiom(fol)"@en .


###  http://purl.obolibrary.org/obo/IAO_0010000
obo:IAO_0010000 rdf:type owl:AnnotationProperty ;
                rdfs:label "has axiom label"@en .


###  http://purl.org/dc/dcam/rangeIncludes
dcam:rangeIncludes rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#definition
prov:definition rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.smolang.org/bedreflyt/bedAssignedTo
bedreflyt:bedAssignedTo rdf:type owl:ObjectProperty ;
                        owl:inverseOf bedreflyt:hasBedAssignment .


###  http://www.smolang.org/bedreflyt/hasAssignTRoom
bedreflyt:hasAssignTRoom rdf:type owl:ObjectProperty ;
                         owl:inverseOf bedreflyt:isAssignWard .


###  http://www.smolang.org/bedreflyt/hasBathroom
bedreflyt:hasBathroom rdf:type owl:ObjectProperty ;
                      owl:inverseOf bedreflyt:isBathroomOf .


###  http://www.smolang.org/bedreflyt/hasBedAssignment
bedreflyt:hasBedAssignment rdf:type owl:ObjectProperty ;
                           rdfs:domain <https://w3id.org/rec/core/Room> ;
                           rdfs:range bedreflyt:Bed .


###  http://www.smolang.org/bedreflyt/hasCity
bedreflyt:hasCity rdf:type owl:ObjectProperty ;
                  rdfs:domain brick:Hospital ;
                  rdfs:range bedreflyt:City .


###  http://www.smolang.org/bedreflyt/hasFinalStep
bedreflyt:hasFinalStep rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       owl:inverseOf bedreflyt:isFinalStepOf .


###  http://www.smolang.org/bedreflyt/hasMonitoringStatus
bedreflyt:hasMonitoringStatus rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf owl:topObjectProperty ;
                              owl:inverseOf bedreflyt:isMonitoringStatusOf .


###  http://www.smolang.org/bedreflyt/hasPhase
bedreflyt:hasPhase rdf:type owl:ObjectProperty ;
                   owl:inverseOf bedreflyt:isPhaseOf .


###  http://www.smolang.org/bedreflyt/hasTask
bedreflyt:hasTask rdf:type owl:ObjectProperty ;
                  owl:inverseOf bedreflyt:isTaskOf .


###  http://www.smolang.org/bedreflyt/hasTreatmentProc
bedreflyt:hasTreatmentProc rdf:type owl:ObjectProperty ;
                           owl:inverseOf bedreflyt:isTreatmentProcOf .


###  http://www.smolang.org/bedreflyt/isAssignHospital
bedreflyt:isAssignHospital rdf:type owl:ObjectProperty ;
                           rdfs:domain brick:Room ;
                           rdfs:range brick:Hospital .


###  http://www.smolang.org/bedreflyt/isAssignWard
bedreflyt:isAssignWard rdf:type owl:ObjectProperty .


###  http://www.smolang.org/bedreflyt/isBathroomOf
bedreflyt:isBathroomOf rdf:type owl:ObjectProperty .


###  http://www.smolang.org/bedreflyt/isFinalStepOf
bedreflyt:isFinalStepOf rdf:type owl:ObjectProperty .


###  http://www.smolang.org/bedreflyt/isMonitoringStatusOf
bedreflyt:isMonitoringStatusOf rdf:type owl:ObjectProperty .


###  http://www.smolang.org/bedreflyt/isPhaseOf
bedreflyt:isPhaseOf rdf:type owl:ObjectProperty .


###  http://www.smolang.org/bedreflyt/isTaskOf
bedreflyt:isTaskOf rdf:type owl:ObjectProperty .


###  http://www.smolang.org/bedreflyt/isTreatmentProcOf
bedreflyt:isTreatmentProcOf rdf:type owl:ObjectProperty .


###  http://www.smolang.org/bedreflyt/stepOfTreatment
bedreflyt:stepOfTreatment rdf:type owl:ObjectProperty ;
                          owl:inverseOf pko:hasStep ;
                          rdfs:domain <http://purl.org/net/p-plan#Step> ;
                          rdfs:range pko:Procedure .


###  https://brickschema.org/schema/Brick#hasFloor
brick:hasFloor rdf:type owl:ObjectProperty ;
               rdfs:domain bedreflyt:Ward ;
               rdfs:range brick:Floor ;
               rdfs:comment "Relates a hospital to its floors." ;
               rdfs:label "has floor" .


###  https://brickschema.org/schema/Brick#hasHospital
brick:hasHospital rdf:type owl:ObjectProperty ;
                  rdfs:domain bedreflyt:Ward ;
                  rdfs:range brick:Hospital .


###  https://brickschema.org/schema/Brick#hasRoom
brick:hasRoom rdf:type owl:ObjectProperty ;
              rdfs:domain bedreflyt:Ward ;
              rdfs:range brick:Room ;
              rdfs:comment "Relates a ward to its rooms." ;
              rdfs:label "has room" .


###  https://w3id.org/pko#hasFirstStep
pko:hasFirstStep rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 obo:IAO_0000412 "https://w3id.org/pko/1.0.0" ;
                 rdfs:label "hasFirstStep" ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure or a MultiStep to its first Step."@en .


###  https://w3id.org/pko#hasStep
pko:hasStep rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            obo:IAO_0000412 "https://w3id.org/pko/1.0.0" ;
            rdfs:label "hasStep" ;
            skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure or a MultiStep to its Steps."@en .


###  https://w3id.org/pko#nextStep
pko:nextStep rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             obo:IAO_0000412 "https://w3id.org/pko/1.0.0" ;
             rdfs:label "nextStep" ;
             skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to its direct next Step."@en .


###  https://w3id.org/pko#previousStep
pko:previousStep rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 obo:IAO_0000412 "https://w3id.org/pko/1.0.0" ;
                 rdfs:label "previousStep" ;
                 skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to its direct previous Step."@en .


###  https://w3id.org/rec/lease/premisesIncludes
<https://w3id.org/rec/lease/premisesIncludes> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf owl:topObjectProperty ;
                                              obo:IAO_0000412 "https://w3id.org/rec/full/3.0/" ;
                                              rdfs:comment "Parthood traversal property linking Premises to their constituent Buildings or Rooms."@en ;
                                              rdfs:label "premisesIncludes"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.smolang.org/bedreflyt/cityName
bedreflyt:cityName rdf:type owl:DatatypeProperty ;
                   rdfs:domain bedreflyt:City ;
                   rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt/diagnosisCode
bedreflyt:diagnosisCode rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf owl:topDataProperty ;
                        rdfs:domain bedreflyt:Diagnosis ;
                        rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt/floorNumber
bedreflyt:floorNumber rdf:type owl:DatatypeProperty ;
                      rdfs:domain brick:Floor ;
                      rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt/hasAvgLength
bedreflyt:hasAvgLength rdf:type owl:DatatypeProperty ;
                       rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt/hasCapacityNrBeds
bedreflyt:hasCapacityNrBeds rdf:type owl:DatatypeProperty ;
                            rdfs:domain <https://w3id.org/rec/core/Room> ;
                            rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt/hasFrequency
bedreflyt:hasFrequency rdf:type owl:DatatypeProperty ;
                       rdfs:domain pko:Procedure ;
                       rdfs:range xsd:double .


###  http://www.smolang.org/bedreflyt/hasMonitoringCode
bedreflyt:hasMonitoringCode rdf:type owl:DatatypeProperty ;
                            rdfs:domain bedreflyt:MonitoringCategory ;
                            rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt/hasNurseBurden
bedreflyt:hasNurseBurden rdf:type owl:DatatypeProperty ;
                         rdfs:domain bedreflyt:TreatmentStep ;
                         rdfs:range xsd:double .


###  http://www.smolang.org/bedreflyt/hasRoomNr
bedreflyt:hasRoomNr rdf:type owl:DatatypeProperty ;
                    rdfs:domain <https://w3id.org/rec/core/Room> ;
                    rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt/hasWeight
bedreflyt:hasWeight rdf:type owl:DatatypeProperty ;
                    rdfs:domain pko:Procedure ;
                    rdfs:range xsd:double .


###  http://www.smolang.org/bedreflyt/hospitalCode
bedreflyt:hospitalCode rdf:type owl:DatatypeProperty ;
                       rdfs:domain brick:Hospital ;
                       rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt/hospitalName
bedreflyt:hospitalName rdf:type owl:DatatypeProperty ;
                       rdfs:domain brick:Hospital ;
                       rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt/monitoringName
bedreflyt:monitoringName rdf:type owl:DatatypeProperty ;
                         rdfs:domain bedreflyt:MonitoringCategory ;
                         rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt/procedureName
bedreflyt:procedureName rdf:type owl:DatatypeProperty ;
                        rdfs:domain pko:Procedure ;
                        rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt/taskName
bedreflyt:taskName rdf:type owl:DatatypeProperty ;
                   rdfs:domain <http://purl.org/net/p-plan#Step> ;
                   rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt/wardName
bedreflyt:wardName rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain bedreflyt:Ward ;
                   rdfs:range xsd:string .


###  http://www.w3.org/2006/time#hours
time:hours rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain <http://purl.org/net/p-plan#Step> ;
           rdfs:range xsd:double ;
           obo:IAO_0000412 "http://www.w3.org/2006/time#2016" ;
           rdfs:comment "Longitud de, o elemento de la longitud de, una extensión temporal expresada en horas."@es ,
                        "length of, or element of the length of, a temporal extent expressed in hours"@en ;
           rdfs:label "duración en horas"@es ,
                      "hoursDuration"@en ;
           skos:definition "Longitud de, o elemento de la longitud de, una extensión temporal expresada en horas."@es ,
                           "length of, or element of the length of, a temporal extent expressed in hours"@en .


###  http://www.w3.org/2006/time#numericDuration
time:numericDuration rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf owl:topDataProperty ;
                     obo:IAO_0000412 "https://w3id.org/pko/1.0.0" ;
                     dcam:rangeIncludes xsd:date ;
                     rdfs:label "numericDuration" ;
                     skos:scopeNote "In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the value of a temporal extent expressed as a number scaled by a temporal unit (in the form of xsd:decimal)."@en .


###  https://w3id.org/pko#stepNumber
pko:stepNumber rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf owl:topDataProperty ;
               rdfs:domain bedreflyt:TreatmentStep ;
               rdfs:range xsd:int ;
               obo:IAO_0000412 "https://w3id.org/pko/1.0.0" ;
               rdfs:label "stepNumber" .


#################################################################
#    Classes
#################################################################

###  http://purl.org/net/p-plan#Step
<http://purl.org/net/p-plan#Step> rdf:type owl:Class ;
                                  obo:IAO_0000412 "http://purl.org/net/p-plan#" ;
                                  rdfs:isDefinedBy <http://purl.org/net/p-plan#> ;
                                  rdfs:label "Task"@en ;
                                  prov:definition "A p-plan:Step represents the planned execution activity"@en .


###  http://www.smolang.org/bedreflyt/Bed
bedreflyt:Bed rdf:type owl:Class ;
              rdfs:subClassOf bedreflyt:Equipment ;
              rdfs:comment "This could come from REC or BRICKS, it is a subclass of Furniture there. However, I would consider it medical equipment, given that these beds have medical functionality (lots of buttoms and special properties that make them more than furniture). So, therefore I do not import from REC." ,
                           "ref to REC <https://w3id.org/rec>:589:14" .


###  http://www.smolang.org/bedreflyt/City
bedreflyt:City rdf:type owl:Class ;
               rdfs:subClassOf bedreflyt:Region .


###  http://www.smolang.org/bedreflyt/Diagnosis
bedreflyt:Diagnosis rdf:type owl:Class ;
                    rdfs:comment "Diagnosis is an ICD Code." .


###  http://www.smolang.org/bedreflyt/Equipment
bedreflyt:Equipment rdf:type owl:Class .


###  http://www.smolang.org/bedreflyt/Facility
bedreflyt:Facility rdf:type owl:Class .


###  http://www.smolang.org/bedreflyt/MonitoringCategory
bedreflyt:MonitoringCategory rdf:type owl:Class .


###  http://www.smolang.org/bedreflyt/Region
bedreflyt:Region rdf:type owl:Class .


###  http://www.smolang.org/bedreflyt/TreatmentStep
bedreflyt:TreatmentStep rdf:type owl:Class .


###  http://www.smolang.org/bedreflyt/Ward
bedreflyt:Ward rdf:type owl:Class ;
               rdfs:subClassOf bedreflyt:Facility .


###  http://www.w3.org/2006/time#Duration
time:Duration rdf:type owl:Class ;
              obo:IAO_0000412 "http://www.w3.org/2006/time#2016" ;
              rdfs:comment "Duración de una extensión temporal expresada como un número escalado por una unidad temporal."@es ,
                           "Duration of a temporal extent expressed as a number scaled by a temporal unit"@en ;
              rdfs:label "Time duration"@en ,
                         "duración de tiempo" ;
              skos:definition "Duración de una extensión temporal expresada como un número escalado por una unidad temporal."@es ,
                              "Duration of a temporal extent expressed as a number scaled by a temporal unit"@en ;
              skos:note "Alternativa a 'descripción de tiempo' para proporcionar descripción soporte a una duración temporal diferente a utilizar un sistema de calendario/reloj."@es ,
                        "Alternative to time:DurationDescription to support description of a temporal duration other than using a calendar/clock system."@en .


###  http://www.w3.org/2006/time#DurationDescription
time:DurationDescription rdf:type owl:Class ;
                         rdfs:subClassOf time:GeneralDurationDescription ;
                         obo:IAO_0000412 "http://www.w3.org/2006/time#2016" ;
                         rdfs:comment "Descripción de extensión temporal estructurada con valores separados para los distintos elementos de un sistema de horario-calendario. El sistema de referencia temporal se fija al calendario gregoriano, y el intervalo de cada una de las propiedades numéricas se restringe a xsd:decimal."@es ,
                                      "Description of temporal extent structured with separate values for the various elements of a calendar-clock system. The temporal reference system is fixed to Gregorian Calendar, and the range of each of the numeric properties is restricted to xsd:decimal"@en ;
                         rdfs:label "Duration description"@en ,
                                    "descripción de duración"@es ;
                         skos:definition "Descripción de extensión temporal estructurada con valores separados para los distintos elementos de un sistema de horario-calendario. El sistema de referencia temporal se fija al calendario gregoriano, y el intervalo de cada una de las propiedades numéricas se restringe a xsd:decimal."@es ,
                                         "Description of temporal extent structured with separate values for the various elements of a calendar-clock system. The temporal reference system is fixed to Gregorian Calendar, and the range of each of the numeric properties is restricted to xsd:decimal"@en ;
                         skos:note "En el calendario gregoriano la longitud de los meses no es fija. Por lo tanto, un valor como \"2,5 meses\" no se puede comparar exactamente con una duración similar expresada en términos de semanas o días."@es ,
                                   "In the Gregorian calendar the length of the month is not fixed. Therefore, a value like \"2.5 months\" cannot be exactly compared with a similar duration expressed in terms of weeks or days."@en .


###  http://www.w3.org/2006/time#GeneralDurationDescription
time:GeneralDurationDescription rdf:type owl:Class ;
                                rdfs:subClassOf time:Duration ;
                                obo:IAO_0000412 "http://www.w3.org/2006/time#2016" ;
                                rdfs:comment "Descripción de extensión temporal estructurada con valores separados para los distintos elementos de un sistema de horario-calendario."@es ,
                                             "Description of temporal extent structured with separate values for the various elements of a calendar-clock system."@en ;
                                rdfs:label "Generalized duration description"@en ,
                                           "descripción de duración generalizada"@es ;
                                skos:definition "Descripción de extensión temporal estructurada con valores separados para los distintos elementos de un sistema de horario-calendario."@es ,
                                                "Description of temporal extent structured with separate values for the various elements of a calendar-clock system."@en ;
                                skos:note "La extensión de una duración de tiempo expresada como una 'descripción de duración general' depende del Sistema de Referencia Temporal. En algunos calendarios la longitud de la semana o del mes no es constante a lo largo del año. Por tanto, un valor como \"25 meses\" puede no ser necesariamente ser comparado con un duración similar expresada en términos de semanas o días. Cuando se consideran calendarios que no están basados en el movimiento de la Tierra, se deben tomar incluso más precauciones en la comparación de duraciones."@es ,
                                          "The extent of a time duration expressed as a GeneralDurationDescription depends on the Temporal Reference System. In some calendars the length of the week or month is not constant within the year. Therefore, a value like \"2.5 months\" may not necessarily be exactly compared with a similar duration expressed in terms of weeks or days. When non-earth-based calendars are considered even more care must be taken in comparing durations."@en .


###  https://brickschema.org/schema/Brick#Building
brick:Building rdf:type owl:Class ;
               rdfs:comment "A building or complex." ;
               rdfs:label "Building" .


###  https://brickschema.org/schema/Brick#Floor
brick:Floor rdf:type owl:Class ;
            rdfs:subClassOf brick:Building ;
            rdfs:comment "A level of a building, typically containing multiple rooms." ;
            rdfs:label "Floor" .


###  https://brickschema.org/schema/Brick#Hospital
brick:Hospital rdf:type owl:Class ;
               rdfs:comment "A building or complex that provides medical care." ;
               rdfs:label "Hospital" .


###  https://brickschema.org/schema/Brick#Room
brick:Room rdf:type owl:Class .


###  https://w3id.org/pko#Procedure
pko:Procedure rdf:type owl:Class ;
              obo:IAO_0000412 "https://w3id.org/pko/1.0.0" ;
              rdfs:comment "A Procedure represents a sequence of actions to be executed in order to achieve a desired outcome."@en ,
                           "A treatment journey is represented as a single long procedure using PKO." ,
                           "The Procedure is a documented sequence of steps. These steps are either directly obtained from experts (healthcare personnel), from written documentation or guidelines, or they can come from learned sequences of actions that are observed by sensors or other similar means." ;
              rdfs:label "Treatment" .


###  https://w3id.org/rec/building/Bathroom
<https://w3id.org/rec/building/Bathroom> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://w3id.org/rec/core/Room> ;
                                         obo:IAO_0000412 "https://w3id.org/rec/full/3.0/" ;
                                         rdfs:label "Bathroom"@en .


###  https://w3id.org/rec/building/TreatmentRoom
<https://w3id.org/rec/building/TreatmentRoom> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://w3id.org/rec/core/Room> ;
                                              obo:IAO_0000412 "https://w3id.org/rec/full/3.0/" ;
                                              rdfs:comment "For e.g. medical or other treatment or consultation."@en ;
                                              rdfs:label "TreatmentRoom"@en .


###  https://w3id.org/rec/core/Room
<https://w3id.org/rec/core/Room> rdf:type owl:Class ;
                                 rdfs:subClassOf bedreflyt:Facility ;
                                 obo:IAO_0000412 "https://w3id.org/rec/full/3.0/" ;
                                 rdfs:comment "Base class for all more specific room types."@en ;
                                 rdfs:label "Room"@en .


#################################################################
#    Individuals
#################################################################

###  http://www.smolang.org/bedreflyt/AngiografiskUndersøkelse
bedreflyt:AngiografiskUndersøkelse rdf:type owl:NamedIndividual ,
                                            <http://purl.org/net/p-plan#Step> ;
                                   bedreflyt:taskName "Angiografisk Undersøkelse" .


###  http://www.smolang.org/bedreflyt/Arrival
bedreflyt:Arrival rdf:type owl:NamedIndividual ,
                           <http://purl.org/net/p-plan#Step> ;
