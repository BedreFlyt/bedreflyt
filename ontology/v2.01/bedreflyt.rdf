    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#hours -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#hours">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://purl.org/net/p-plan#Step"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <obo:IAO_0000412>http://www.w3.org/2006/time#2016</obo:IAO_0000412>
        <rdfs:comment xml:lang="es">Longitud de, o elemento de la longitud de, una extensión temporal expresada en horas.</rdfs:comment>
        <rdfs:comment xml:lang="en">length of, or element of the length of, a temporal extent expressed in hours</rdfs:comment>
        <rdfs:label xml:lang="es">duración en horas</rdfs:label>
        <rdfs:label xml:lang="en">hoursDuration</rdfs:label>
        <skos:definition xml:lang="es">Longitud de, o elemento de la longitud de, una extensión temporal expresada en horas.</skos:definition>
        <skos:definition xml:lang="en">length of, or element of the length of, a temporal extent expressed in hours</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#numericDuration -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#numericDuration">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <obo:IAO_0000412>https://w3id.org/pko/1.0.0</obo:IAO_0000412>
        <dcam:rangeIncludes rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>numericDuration</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to represent the value of a temporal extent expressed as a number scaled by a temporal unit (in the form of xsd:decimal).</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pko#stepNumber -->

