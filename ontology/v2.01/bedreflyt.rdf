<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/laurasla/ontologies/2025/1/untitled-ontology-134/"
     xml:base="http://www.semanticweb.org/laurasla/ontologies/2025/1/untitled-ontology-134/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:pko="https://w3id.org/pko#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:dcam="http://purl.org/dc/dcam/"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:bedreflyt="http://www.smolang.org/bedreflyt/">
    <owl:Ontology rdf:about="http://www.smolang.org/bedreflyt/">
        <owl:versionIRI rdf:resource="http://www.smolang.org/bedreflyt/2.0.1"/>
        <rdfs:comment>Knowledge about treatment workflows, objects relevant to the workflow such as beds, personnel types involved in the workflow.</rdfs:comment>
    </owl:Ontology>
    


