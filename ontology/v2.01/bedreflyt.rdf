        <rdfs:comment xml:lang="en">For e.g. medical or other treatment or consultation.</rdfs:comment>
        <rdfs:label xml:lang="en">TreatmentRoom</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/rec/core/Room -->

