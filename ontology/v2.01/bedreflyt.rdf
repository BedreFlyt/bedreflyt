     -->

    


    <!-- http://www.smolang.org/bedreflyt/bedAssignedTo -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/bedAssignedTo">
        <owl:inverseOf rdf:resource="http://www.smolang.org/bedreflyt/hasBedAssignment"/>
    </owl:ObjectProperty>
    


    <!-- http://www.smolang.org/bedreflyt/hasAssignTRoom -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/hasAssignTRoom">
        <owl:inverseOf rdf:resource="http://www.smolang.org/bedreflyt/isAssignWard"/>
    </owl:ObjectProperty>
    


    <!-- http://www.smolang.org/bedreflyt/hasBathroom -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/hasBathroom">
        <owl:inverseOf rdf:resource="http://www.smolang.org/bedreflyt/isBathroomOf"/>
    </owl:ObjectProperty>
    


    <!-- http://www.smolang.org/bedreflyt/hasBedAssignment -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/hasBedAssignment">
        <rdfs:domain rdf:resource="https://w3id.org/rec/core/Room"/>
        <rdfs:range rdf:resource="http://www.smolang.org/bedreflyt/Bed"/>
    </owl:ObjectProperty>
    


    <!-- http://www.smolang.org/bedreflyt/hasFinalStep -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/hasFinalStep">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.smolang.org/bedreflyt/isFinalStepOf"/>
    </owl:ObjectProperty>
    


    <!-- http://www.smolang.org/bedreflyt/hasMonitoringStatus -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/hasMonitoringStatus">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.smolang.org/bedreflyt/isMonitoringStatusOf"/>
    </owl:ObjectProperty>
    


    <!-- http://www.smolang.org/bedreflyt/hasPhase -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/hasPhase">
        <owl:inverseOf rdf:resource="http://www.smolang.org/bedreflyt/isPhaseOf"/>
    </owl:ObjectProperty>
    


    <!-- http://www.smolang.org/bedreflyt/hasTask -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/hasTask">
        <owl:inverseOf rdf:resource="http://www.smolang.org/bedreflyt/isTaskOf"/>
    </owl:ObjectProperty>
    


    <!-- http://www.smolang.org/bedreflyt/hasTreatmentProc -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/hasTreatmentProc">
        <owl:inverseOf rdf:resource="http://www.smolang.org/bedreflyt/isTreatmentProcOf"/>
    </owl:ObjectProperty>
    


    <!-- http://www.smolang.org/bedreflyt/isAssignWard -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/isAssignWard"/>
    


    <!-- http://www.smolang.org/bedreflyt/isBathroomOf -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/isBathroomOf"/>
    


    <!-- http://www.smolang.org/bedreflyt/isFinalStepOf -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/isFinalStepOf"/>
    


    <!-- http://www.smolang.org/bedreflyt/isMonitoringStatusOf -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/isMonitoringStatusOf"/>
    


    <!-- http://www.smolang.org/bedreflyt/isPhaseOf -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/isPhaseOf"/>
    


    <!-- http://www.smolang.org/bedreflyt/isTaskOf -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/isTaskOf"/>
    


    <!-- http://www.smolang.org/bedreflyt/isTreatmentProcOf -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/isTreatmentProcOf"/>
    


    <!-- http://www.smolang.org/bedreflyt/stepOfTreatment -->

    <owl:ObjectProperty rdf:about="http://www.smolang.org/bedreflyt/stepOfTreatment">
        <owl:inverseOf rdf:resource="https://w3id.org/pko#hasStep"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko#hasFirstStep -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pko#hasFirstStep">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000412>https://w3id.org/pko/1.0.0</obo:IAO_0000412>
        <rdfs:label>hasFirstStep</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure or a MultiStep to its first Step.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko#hasStep -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pko#hasStep">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000412>https://w3id.org/pko/1.0.0</obo:IAO_0000412>
        <rdfs:label>hasStep</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Procedure or a MultiStep to its Steps.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko#nextStep -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pko#nextStep">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000412>https://w3id.org/pko/1.0.0</obo:IAO_0000412>
        <rdfs:label>nextStep</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to its direct next Step.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pko#previousStep -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pko#previousStep">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000412>https://w3id.org/pko/1.0.0</obo:IAO_0000412>
        <rdfs:label>previousStep</rdfs:label>
        <skos:scopeNote xml:lang="en">In the context of the Procedural Knowledge Ontology (PKO), this property is used to link a Step to its direct previous Step.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/rec/lease/premisesIncludes -->

    <owl:ObjectProperty rdf:about="https://w3id.org/rec/lease/premisesIncludes">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000412>https://w3id.org/rec/full/3.0/</obo:IAO_0000412>
        <rdfs:comment xml:lang="en">Parthood traversal property linking Premises to their constituent Buildings or Rooms.</rdfs:comment>
        <rdfs:label xml:lang="en">premisesIncludes</rdfs:label>
    </owl:ObjectProperty>
    


