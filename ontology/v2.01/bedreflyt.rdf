        <obo:IAO_0000412>https://w3id.org/rec/full/3.0/</obo:IAO_0000412>
        <rdfs:comment xml:lang="en">Base class for all more specific room types.</rdfs:comment>
        <rdfs:label xml:lang="en">Room</rdfs:label>
    </owl:Class>
    


