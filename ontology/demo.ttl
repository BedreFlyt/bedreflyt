@prefix : <http://www.bedreflyt.org/demo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.bedreflyt.org/demo/> .

<http://www.bedreflyt.org/demo> rdf:type owl:Ontology ;
                                 owl:versionIRI :v1 .

#################################################################
#    Object Properties
#################################################################

###  http://www.bedreflyt.org/demo/assigned_diagnostic_code
:assigned_diagnostic_code rdf:type owl:ObjectProperty ;
                          rdfs:domain :Patient ;
                          rdfs:range :Diagnostic_Code .


###  http://www.bedreflyt.org/demo/has_bed_assignment
:has_bed_assignment rdf:type owl:ObjectProperty ;
                    rdfs:domain :Task ;
                    rdfs:range :BedCategory .


###  http://www.bedreflyt.org/demo/has_seq_journey_order
:has_seq_journey_order rdf:type owl:ObjectProperty .


###  http://www.bedreflyt.org/demo/undergoes_surg_proc
:undergoes_surg_proc rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :undergoes_treatment_proc .


###  http://www.bedreflyt.org/demo/undergoes_treatment_proc
:undergoes_treatment_proc rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  http://www.bedreflyt.org/demo#fairCareTreAssign
:fairCareTreAssign rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :fairCareTreatment
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :has_bed_assignment ;
                                                                owl:allValuesFrom :intermediar
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf :BedAssignment .


###  http://www.bedreflyt.org/demo/BedAssignment
:BedAssignment rdf:type owl:Class .


###  http://www.bedreflyt.org/demo/BedCategory
:BedCategory rdf:type owl:Class .


###  http://www.bedreflyt.org/demo/Diagnostic_Code
:Diagnostic_Code rdf:type owl:Class .


###  http://www.bedreflyt.org/demo/G912
:G912 rdf:type owl:Class ;
      rdfs:subClassOf :Diagnostic_Code .


###  http://www.bedreflyt.org/demo/I60
:I60 rdf:type owl:Class ;
     rdfs:subClassOf :Diagnostic_Code .


###  http://www.bedreflyt.org/demo/M500
:M500 rdf:type owl:Class ;
      rdfs:subClassOf :Diagnostic_Code .


###  http://www.bedreflyt.org/demo/Patient
:Patient rdf:type owl:Class .


###  http://www.bedreflyt.org/demo/Task
:Task rdf:type owl:Class .


###  http://www.bedreflyt.org/demo/WF
:WF rdf:type owl:Class .


###  http://www.bedreflyt.org/demo/acuteArrivalAssign
:acuteArrivalAssign rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( :acuteArrivalCritical
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :has_bed_assignment ;
                                                                 owl:allValuesFrom :overvaakning
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf :BedAssignment .


###  http://www.bedreflyt.org/demo/acuteArrivalCritical
:acuteArrivalCritical rdf:type owl:Class ;
                      rdfs:subClassOf :Task .


###  http://www.bedreflyt.org/demo/acuteBrainBleeding
:acuteBrainBleeding rdf:type owl:Class ;
                    rdfs:subClassOf :WF .


###  http://www.bedreflyt.org/demo/criticalCareTreatAssign
:criticalCareTreatAssign rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( :criticalCareTreatment
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :has_bed_assignment ;
                                                                      owl:allValuesFrom :overvaakning
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf :BedAssignment .


###  http://www.bedreflyt.org/demo/criticalCareTreatment
:criticalCareTreatment rdf:type owl:Class ;
                       rdfs:subClassOf :Task .


###  http://www.bedreflyt.org/demo/fairCareTreatment
:fairCareTreatment rdf:type owl:Class ;
                   rdfs:subClassOf :Task .


###  http://www.bedreflyt.org/demo/intermediar
:intermediar rdf:type owl:Class ;
             rdfs:subClassOf :BedCategory .


###  http://www.bedreflyt.org/demo/m500SurgeryTreatment
:m500SurgeryTreatment rdf:type owl:Class ;
                      rdfs:subClassOf :Task .


###  http://www.bedreflyt.org/demo/operasjonG912
:operasjonG912 rdf:type owl:Class ;
               rdfs:subClassOf :Task .


###  http://www.bedreflyt.org/demo/overvaakning
:overvaakning rdf:type owl:Class ;
              rdfs:subClassOf :BedCategory .


###  http://www.bedreflyt.org/demo/plannedArrivalGood
:plannedArrivalGood rdf:type owl:Class ;
                    rdfs:subClassOf :Task .


###  http://www.bedreflyt.org/demo/plannedCervicalSurgery
:plannedCervicalSurgery rdf:type owl:Class ;
                        rdfs:subClassOf :WF .


###  http://www.bedreflyt.org/demo/plannedNeckSurgery
:plannedNeckSurgery rdf:type owl:Class ;
                    rdfs:subClassOf :WF .


###  http://www.bedreflyt.org/demo/postOpRecoverGood
:postOpRecoverGood rdf:type owl:Class ;
                   rdfs:subClassOf :Task .


###  http://www.bedreflyt.org/demo/preOpNoBed
:preOpNoBed rdf:type owl:Class ;
            rdfs:subClassOf :BedCategory .


###  http://www.bedreflyt.org/demo/sengepost
:sengepost rdf:type owl:Class ;
           rdfs:subClassOf :BedCategory .


###  http://www.bedreflyt.org/demo/surgicalRoom
:surgicalRoom rdf:type owl:Class ;
              rdfs:subClassOf :BedCategory .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :G912
                :I60
                :M500
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :intermediar
                :overvaakning
                :preOpNoBed
                :sengepost
                :surgicalRoom
              )
] .


