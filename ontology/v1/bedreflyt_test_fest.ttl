#    Object Properties
#################################################################

###  http://www.smolang.org/bedreflyt#hasDiagnosis
:hasDiagnosis rdf:type owl:ObjectProperty ;
              rdfs:domain :Patient ;
              rdfs:range :Diagnosis .


###  http://www.smolang.org/bedreflyt#hasJourneyStep
:hasJourneyStep rdf:type owl:ObjectProperty ;
                rdfs:domain :Patient .


###  http://www.smolang.org/bedreflyt#hasTask
:hasTask rdf:type owl:ObjectProperty ;
         rdfs:range :Task .


