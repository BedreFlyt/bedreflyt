@prefix : <http://www.smolang.org/bedreflyt#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.smolang.org/bedreflyt#> .

<http://www.smolang.org/bedreflyt> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.smolang.org/bedreflyt#hasDependency
:hasDependency rdf:type owl:ObjectProperty .


###  http://www.smolang.org/bedreflyt#hasDiagnosis
:hasDiagnosis rdf:type owl:ObjectProperty ;
              rdfs:domain :Patient ;
              rdfs:range :Diagnosis .


###  http://www.smolang.org/bedreflyt#hasJourneyStep
:hasJourneyStep rdf:type owl:ObjectProperty ;
                rdfs:domain :Patient ;
                rdfs:range :JourneyStep .


###  http://www.smolang.org/bedreflyt#hasTask
:hasTask rdf:type owl:ObjectProperty ;
         rdfs:domain :JourneyStep ;
         rdfs:range :Task .


#################################################################
#    Data properties
#################################################################

###  http://www.smolang.org/bedreflyt#averageDuration
:averageDuration rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Task ;
                 rdfs:range xsd:double .


###  http://www.smolang.org/bedreflyt#bathroom
:bathroom rdf:type owl:DatatypeProperty ;
          rdfs:domain :RoomDistribution ;
          rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt#bed
:bed rdf:type owl:DatatypeProperty ;
     rdfs:domain :Task ;
     rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt#bedCategory
:bedCategory rdf:type owl:DatatypeProperty ;
             rdfs:domain :Room ;
             rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt#bedType
:bedType rdf:type owl:DatatypeProperty ;
         rdfs:domain :JourneyStep ;
         rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt#capacity
:capacity rdf:type owl:DatatypeProperty ;
          rdfs:domain :RoomDistribution ;
          rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt#diagnosis
:diagnosis rdf:type owl:DatatypeProperty ;
           rdfs:domain :JourneyStep ;
           rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt#diagnosisName
:diagnosisName rdf:type owl:DatatypeProperty ;
               rdfs:domain :Diagnosis ;
               rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt#orderInJourney
:orderInJourney rdf:type owl:DatatypeProperty ;
                rdfs:domain :JourneyStep ;
                rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt#room
:room rdf:type owl:DatatypeProperty ;
      rdfs:domain :RoomDistribution ;
      rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt#roomDescription
:roomDescription rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Room ;
                 rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt#roomNumber
:roomNumber rdf:type owl:DatatypeProperty ;
            rdfs:domain :RoomDistribution ;
            rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt#roomNumberModel
:roomNumberModel rdf:type owl:DatatypeProperty ;
                 rdfs:domain :RoomDistribution ;
                 rdfs:range xsd:integer .


###  http://www.smolang.org/bedreflyt#task
:task rdf:type owl:DatatypeProperty ;
      rdfs:domain :JourneyStep ;
      rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt#taskDependent
:taskDependent rdf:type owl:DatatypeProperty ;
               rdfs:domain :Task ;
               rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt#taskName
:taskName rdf:type owl:DatatypeProperty ;
          rdfs:domain :Task ;
          rdfs:range xsd:string .


###  http://www.smolang.org/bedreflyt#taskToWait
:taskToWait rdf:type owl:DatatypeProperty ;
            rdfs:domain :Task ;
            rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://www.smolang.org/bedreflyt#Diagnosis
:Diagnosis rdf:type owl:Class ;
           rdfs:subClassOf :Treatment .


###  http://www.smolang.org/bedreflyt#JourneyStep
:JourneyStep rdf:type owl:Class ;
             rdfs:subClassOf :Treatment .


###  http://www.smolang.org/bedreflyt#Patient
:Patient rdf:type owl:Class .


###  http://www.smolang.org/bedreflyt#Room
:Room rdf:type owl:Class .


###  http://www.smolang.org/bedreflyt#RoomDistribution
:RoomDistribution rdf:type owl:Class .


###  http://www.smolang.org/bedreflyt#Task
:Task rdf:type owl:Class ;
      rdfs:subClassOf :Treatment .


###  http://www.smolang.org/bedreflyt#TaskDependency
:TaskDependency rdf:type owl:Class ;
                rdfs:subClassOf :Treatment .


###  http://www.smolang.org/bedreflyt#Treatment
:Treatment rdf:type owl:Class .


