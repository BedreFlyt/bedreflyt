//------------------------------------------------------------------------------------------------
//--------------------------------- TASKS & WORKFLOWS KB --TREATMENTS ----------------------------
//------------------------------------------------------------------------------------------------
def List<String> taskDepAux(String taskName) =
        builtin(sqlite3,
        "../dataTest/trData.db" ,
        "SELECT taskDependency  FROM taskDependencies WHERE taskName = ?",taskName);

data TaskDB = TaskDB(String iddb, Int categorydb, Int daysdb);
def List<TaskDB> taskAux(String name) =
        builtin(sqlite3,
        "../dataTest/trData.db" ,
        "SELECT name, bedCategory, durAvg FROM tasks WHERE name = ?",name);

def List<String> wfAux1(String treatmentName) =
        builtin(sqlite3,
        "../dataTest/trData.db" ,
        "SELECT taskName  FROM treatments  WHERE treatmentName= ? ORDER BY orderTask", treatmentName);

def List<String> trAux1() =
        builtin(sqlite3,
        "../dataTest/trData.db" ,
        "SELECT DISTINCT treatmentName  FROM treatments");



def Task task(String taskName) =
    let List<TaskDB> tdb =  taskAux(taskName), Set<String> dep = taskDep(taskName) in
    Task(iddb(head(tdb)),categorydb(head(tdb)),daysdb(head(tdb)),dep);
def Set<String> taskDep(String taskName) = listToSet(taskDepAux(taskName),set[]);
def Set<String> listToSet(List<String> l, Set<String> s ) =
  case l {
    Nil => s;
    Cons(hd,tl) => listToSet(tl,insertElement(s,hd))} ;

def WF wf(String treatmentName) =
    let List<String> lt = wfAux1(treatmentName) in wfAux2(lt,Nil);
def WF wfAux2(List<String> lt, WF wf) =
  case lt {
    Nil => wf;
    Cons(hd,tl) => wfAux2(tl,appendright(wf,task(hd))) } ;

def Treatments trDB() =
        let List<String> trl = trAux1() in trAux2(trl,map[]);
def Treatments trAux2(List<String> trl, Treatments tr) =
case trl {
  Nil => tr;
  Cons(hd,tl) => trAux2(tl,insert(tr,Pair(hd,wf(hd)))) } ;


/////////// BEDS CATEGORY//////////////////

def List<Bed> bcAux1() =
            builtin(sqlite3,
            "../dataTest/roomData.db" ,
            "SELECT DISTINCT catIdModl,roomDescr  FROM roomCategory ORDER BY catIdModl");

def BedsCat bcDB() =
            let List<Bed> b = bcAux1() in bcAux2(b,map[]);

def BedsCat bcAux2(List<Bed> b, BedsCat bc) =
case  b {
  Nil => bc;
  Cons(hd,tl) => bcAux2(tl,insert(bc,Pair(catg(hd),desc(hd)))) } ;


// ----------------------- Run the simulator with internal datastructures

// Task(name, bed-category, duration, task-dependencies)
// duration: is the number of days needed for the task
// bed-category: according to bedscat()

def Task arrival() = Task("arrival", 1, 1, set[]);
def Task analyses() = Task("analyses", 1, 2, set["arrival","surgery1"]);
def Task surgery1() = Task("surgery1", 4, 1, set["arrival"]);
def Task surgery2() = Task("surgery2", 4, 1, set["arrival","analyses"]);
def Task recovery1() = Task("post-surgery1", 2, 1, set["arrival","surgery1"]);
def Task recovery2() = Task("post-surgery2", 3, 1, set["arrival","surgery1"]);
def Task recovery3() = Task("post-surgery3", 3, 2, set["arrival","analyses","surgery2"]);
def Task recovery4() = Task("post-surgery4", 2, 2, set["arrival","analyses","surgery2","post-surgery3"]);

def WF emptyFlow() = list[];
def WF standardTreatment() = list[arrival(), surgery1(), recovery1()];
def WF interTreatment() = list[arrival(), surgery1(), recovery2()];
def WF intenseTreatment1() = list[arrival(), analyses(), surgery2(), recovery3()];
def WF intenseTreatment2() = list[arrival(), analyses(), surgery2(), recovery3(), recovery4()];

// This is the KB input for the simulator
def Treatments treatments() = map[Pair("standard", standardTreatment()),
                                 Pair("inter", interTreatment()),
                                 Pair("intense1",intenseTreatment1()),
                                 Pair("intense2",intenseTreatment2())];

// bed categories
def BedsCat bedscat() = map[Pair(1,"Sengepost"),
                            Pair(2,"Intermediaer"),
                            Pair(3,"Overvaakning"),
                            Pair(4,"Surgery room")];
