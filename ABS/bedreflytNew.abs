//------------------------------------------------------------------------------------------------
//--------------------------------- SCENARIO INSTANTIATION ---------------------------------------
//------------------------------------------------------------------------------------------------
data PairDB = PairDB (String pId, String tId);
def List<PairDB> batchAux1(Int batch) =
        builtin(sqlite3,
        "../dataTest/scData.db" ,
        "SELECT  patientId, treatmentName  FROM scenario WHERE batch = ?",batch);

def List<Int> scAux1() =
        builtin(sqlite3,
        "../dataTest/scData.db" ,
        "SELECT DISTINCT batch FROM scenario  ORDER BY batch");

def OneDayScenario batch(Int batch) =
        let List<PairDB> lpdb = batchAux1(batch) in batchAux2(lpdb,Nil);
def OneDayScenario batchAux2(List<PairDB> lpdb, OneDayScenario odsc) =
  case lpdb {
    Nil => odsc;
    Cons(hd,tl) => batchAux2(tl,appendright(odsc,Pair(pId(hd),tId(hd))))} ;

def Scenario scDB() = let List<Int> lb = scAux1() in scAux2(lb,Nil);
def Scenario scAux2(List<Int> lb, Scenario sc) =
  case lb {
    Nil => sc;
    Cons(hd,tl) => scAux2(tl, appendright(sc,batch(hd)))} ;


//---------------------------Scenario 1------------------------------------
//---- Only one day

def OneDayScenario sc0() = list[Pair("einar","standard"),
                               Pair("rudi","inter"),
                               Pair("lizeth","intense1")];

//---------------------------Senario 2-----------------------------------------
//---- four days in a row, spread over 11 days

def OneDayScenario scArrivingDay1() = list[Pair("einar","standard"),
                                           Pair("rudi","inter")];
def OneDayScenario scArrivingDay2() = list[Pair("lizeth","intense1")];
def OneDayScenario scArrivingDay4() = list[Pair("laura","standard"),
                                           Pair("riccardo","intense2")];

//--------------------------------------------------------------------------------
// This is the Patient stream data input for the simulator

// Activating Scenario 1
//def Scenario sc() = list[sc0()];

// Activating Scenario 2
def Scenario sc() = list[scArrivingDay1(),scArrivingDay2(),Nil,scArrivingDay4()];
