//------------------------------------------------------------------------------------------------
//--------------------------------- TASKS & WORKFLOWS KB --TREATMENTS ----------------------------
//------------------------------------------------------------------------------------------------
def List<String> taskDepAux(String taskName) =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT taskDependency  FROM taskDependencies WHERE taskName = ?",taskName);

data TaskDB = TaskDB(String iddb, Int categorydb, Rat durAvgdb);
def List<TaskDB> taskAux(String name) =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT name, bedCategory, durAvg FROM tasks WHERE name = ?",name);

def List<String> wfAux1(TreatmentID treatmentName) =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT taskName  FROM treatments  WHERE treatmentName= ? ORDER BY orderTask", treatmentName);

def List<String> trAux1() =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT DISTINCT treatmentName  FROM treatments");



def Task task(String taskName) =
    let List<TaskDB> tdb =  taskAux(taskName), Set<String> dep = taskDep(taskName) in
    Task(iddb(head(tdb)),categorydb(head(tdb)),durAvgdb(head(tdb)),dep);

def Set<String> taskDep(String taskName) = set(taskDepAux(taskName));

def Treatment wf(String treatmentName) =
    let List<String> lt = wfAux1(treatmentName)
    in map((String hd) => task(hd))(lt);

def Treatments trDB() =
    let List<String> trl = trAux1()
    in foldl((String hd, Treatments result) => put(result, hd, wf(hd)))(trl, map[]);

/////////// BEDS CATEGORY//////////////////

def List<Bed> bcAux1() =
            builtin(sqlite3,
            "../dataTest/bedreflyt.db",
            "SELECT DISTINCT catIdModl,roomDescr  FROM roomCategory ORDER BY catIdModl");

def BedsCat bcDB() =
    let List<Bed> bedList = bcAux1()
    in foldl((Bed bed, BedsCat result) => put(result, catg(bed), desc(bed)))(bedList, map[]);

//------------------------------------------------------------------------------------------------
//--------------------------------- SCENARIO INSTANTIATION ---------------------------------------
//------------------------------------------------------------------------------------------------
data PairDB = PairDB (String pId, String tId);
def List<PairDB> batchAux1(Int batch) =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT  patientId, treatmentName  FROM scenario WHERE batch = ?",batch);

def List<Int> maxBatch() =
    builtin(sqlite3, "../dataTest/bedreflyt.db", "SELECT IFNULL(MAX(batch), -1) FROM scenario");
def List<Int> minBatch() =
    builtin(sqlite3, "../dataTest/bedreflyt.db", "SELECT IFNULL(MIN(batch), -1) FROM scenario");

// sequence(2, 5) => list[2, 3, 4, 5]
def List<Int> sequence(Int min, Int max) =
    when (min <= max)
    then Cons(min, sequence(min + 1, max))
    else Nil;

def OneTimeStepScenario batch(Int batch) =
    let List<PairDB> lpdb = batchAux1(batch)
    in map((PairDB db) => Pair(pId(db), tId(db)))(lpdb);

def Scenario scDB() =
    let List<Int> batches = sequence(head(minBatch()), head(maxBatch()))
    // This inserts an empty list if there's no batches that time step; this
    // is correct behavior.
    in map((Int batch_nr) => batch(batch_nr))(batches);



//------------------------------------------------------------------------------------------------
//------------Simulation for the selected scenario sc and avaialable treatments tr----------------
//------------------------------------------------------------------------------------------------
{
    // from DB

    Treatments tr = trDB();
    //println("\n" + toString(tr));
    Scenario sc = scDB();
    //println("\n" + toString(sc));
    BedsCat bc = bcDB();
    //println("\n" + toString(bc));

    duration(1);
    ScenarioSimulator scsim = new ScenarioSimulator(tr,sc,bc);
    Unit timeline = scsim.simulateScenario(); // Holds time step objects, where each time step object holds patient needs in that time step

}


