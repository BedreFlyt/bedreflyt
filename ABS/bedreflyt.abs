//------------------------------------------------------------------------------------------------
//--------------------------------- TASKS & WORKFLOWS KB --TREATMENTS ----------------------------
//------------------------------------------------------------------------------------------------
def List<String> taskDepAux(String taskName) =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT taskDependency  FROM taskDependencies WHERE taskName = ?",taskName);

data TaskDB = TaskDB(String iddb, Int categorydb, Int timestepsdb);
def List<TaskDB> taskAux(String name) =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT name, bedCategory, durAvg FROM tasks WHERE name = ?",name);

def List<String> wfAux1(TreatmentID treatmentName) =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT taskName  FROM treatments  WHERE treatmentName= ? ORDER BY orderTask", treatmentName);

def List<String> trAux1() =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT DISTINCT treatmentName  FROM treatments");



def Task task(String taskName) =
    let List<TaskDB> tdb =  taskAux(taskName), Set<String> dep = taskDep(taskName) in
    Task(iddb(head(tdb)),categorydb(head(tdb)),timestepsdb(head(tdb)),dep);

def Set<String> taskDep(String taskName) = set(taskDepAux(taskName));

def Treatment wf(String treatmentName) =
    let List<String> lt = wfAux1(treatmentName)
    in map((String hd) => task(hd))(lt);

def Treatments trDB() =
    let List<String> trl = trAux1()
    in foldl((String hd, Treatments result) => put(result, hd, wf(hd)))(trl, map[]);

/////////// BEDS CATEGORY//////////////////

def List<Bed> bcAux1() =
            builtin(sqlite3,
            "../dataTest/bedreflyt.db",
            "SELECT DISTINCT catIdModl,roomDescr  FROM roomCategory ORDER BY catIdModl");

def BedsCat bcDB() =
    let List<Bed> bedList = bcAux1()
    in foldl((Bed bed, BedsCat result) => put(result, catg(bed), desc(bed)))(bedList, map[]);

// ----------------------- Run the simulator with internal datastructures

// Task(name, bed-category, duration, task-dependencies)
// duration: is the number of time steps needed for the task
// bed-category: according to bedscat()
def Task prearrival() = Task("pre-arrival", 0, 0, set[]);
def Task arrival() = Task("arrival", 1, 1, set["pre-arrival"]);
def Task analyses() = Task("analyses", 1, 2, set["pre-arrival","arrival","surgery1"]);
def Task surgery1() = Task("surgery1", 4, 1, set["pre-arrival","arrival"]);
def Task surgery2() = Task("surgery2", 5, 1, set["pre-arrival","arrival","analyses"]);
def Task recovery1() = Task("post-surgery1", 2, 1, set["pre-arrival","arrival","surgery1"]);
def Task recovery2() = Task("post-surgery2", 3, 1, set["pre-arrival","arrival","surgery1"]);
def Task recovery3() = Task("post-surgery3", 3, 2, set["pre-arrival","arrival","analyses","surgery2"]);
def Task recovery4() = Task("post-surgery4", 2, 2, set["pre-arrival","arrival","analyses","surgery2","post-surgery3"]);

def Treatment emptyFlow() = list[];
def Treatment standardTreatment() = list[prearrival(),arrival(), surgery1(), recovery1()];
def Treatment interTreatment() = list[prearrival(),arrival(), surgery1(), recovery2()];
def Treatment intenseTreatment1() = list[prearrival(),arrival(), analyses(), surgery2(), recovery3()];
def Treatment intenseTreatment2() = list[prearrival(),arrival(), analyses(), surgery2(), recovery3(), recovery4()];

// This is the KB input for the simulator
def Treatments treatments() = map[Pair("standard", standardTreatment()),
                                 Pair("inter", interTreatment()),
                                 Pair("intense1",intenseTreatment1()),
                                 Pair("intense2",intenseTreatment2())];

// bed categories
def BedsCat bedscat() = map[Pair(0,"No bed"),
                            Pair(1,"Sengepost"),
                            Pair(2,"Intermediaer"),
                            Pair(3,"Overvaakning"),
                            Pair(4,"Surgery room 1"),
                            Pair(5,"Surgery room 2")];
