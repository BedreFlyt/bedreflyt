//------------------------------------------------------------------------------------------------
//--------------------------------- TASKS & WORKFLOWS KB --TREATMENTS ----------------------------
//------------------------------------------------------------------------------------------------
// Task(name, bed-category, duration, dependencies)
// duration: is the number of days needed for the task
// bed-category:
//  1 -- Sengepost
//  2 -- Intermediaer
//  3 -- Overvaakning
//  4 -- Surgery room
def Task arrival() = Task("arrival", 1, 1, set[]);
def Task analyses() = Task("analyses", 1, 2, set["arrival"]);
def Task surgery1() = Task("surgery1", 4, 1, set["arrival"]);
def Task surgery2() = Task("surgery2", 4, 1, set["arrival","analyses"]);
def Task recovery1() = Task("post-surgery1", 2, 1, set["arrival","surgery1"]);
def Task recovery2() = Task("post-surgery2", 3, 1, set["arrival","surgery1"]);
def Task recovery3() = Task("post-surgery3", 3, 2, set["arrival","analyses","surgery2"]);
def Task recovery4() = Task("post-surgery4", 2, 2, set["arrival","analyses","surgery2","post-surgery3"]);

def WF emptyFlow() = list[];
def WF standardTreatment() = list[arrival(), surgery1(), recovery1()];
def WF interTreatment() = list[arrival(), surgery1(), recovery2()];
def WF intenseTreatment1() = list[arrival(), analyses(), surgery2(), recovery3()];
def WF intenseTreatment2() = list[arrival(), analyses(), surgery2(), recovery3(), recovery4()];

def Treatments treatments() = map[Pair("standard", standardTreatment()),
                                 Pair("inter", interTreatment()),
                                 Pair("intense1",intenseTreatment1()),
                                 Pair("intense2",intenseTreatment2())];
//------------------------------------------------------------------------------------------------
//------------------------------------------------------------------------------------------------



//------------------------------------------------------------------------------------------------
//--------------------------------- SCENARIO INSTANTIATION ---------------------------------------
//------------------------------------------------------------------------------------------------

//---------------------------Scenario 1------------------------------------
//---- Only one day

def OneDayScenario sc0() = list[Pair("einar","standard"),
                               Pair("rudy","inter"),
                               Pair("lizeth","intense1")];

//---------------------------Senario 2-----------------------------------------
//---- four days in a row, spread over 11 days

def OneDayScenario scArrivingDay1() = list[Pair("einar","standard"),
                                           Pair("rudy","inter")];
def OneDayScenario scArrivingDay2() = list[Pair("lizeth","intense1")];
def OneDayScenario scArrivingDay4() = list[Pair("laura","standard"),
                                           Pair("riccardo","intense2")];

//--------------------------------------------------------------------------------

// Activating Scenario 1
//def Scenario sc() = list[sc0()];

// Activating Scenario 2
def Scenario sc() = list[scArrivingDay1(),scArrivingDay2(),Nil,scArrivingDay4()];
//------------------------------------------------------------------------------------------------
//------------------------------------------------------------------------------------------------


//------------------------------------------------------------------------------------------------
//------------------------------- Simulation for the selected scenario ---------------------------
//------------------------------------------------------------------------------------------------
{
    Treatments tr = treatments(); // static knowledge about treatments
    Scenario sc = sc(); // dynamic stream of patients
    Simulator sim = new Simulator(tr,sc);
    List<BedPostNeeds> timeline = sim.simulate(); // Holds Day objects, where each day object holds patient needs in that day
}


