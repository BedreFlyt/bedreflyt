//------------------------------------------------------------------------------------------------
//--------------------------------- SCENARIO INSTANTIATION ---------------------------------------
//------------------------------------------------------------------------------------------------
data PairDB = PairDB (String pId, String tId);
def List<PairDB> batchAux1(Int batch) =
        builtin(sqlite3,
        "../dataTest/bedreflyt.db" ,
        "SELECT  patientId, treatmentName  FROM scenario WHERE batch = ?",batch);

def List<Int> maxBatch() =
    builtin(sqlite3, "../dataTest/bedreflyt.db", "SELECT IFNULL(MAX(batch), -1) FROM scenario");
def List<Int> minBatch() =
    builtin(sqlite3, "../dataTest/bedreflyt.db", "SELECT IFNULL(MIN(batch), -1) FROM scenario");

// sequence(2, 5) => list[2, 3, 4, 5]
def List<Int> sequence(Int min, Int max) =
    when (min <= max)
    then Cons(min, sequence(min + 1, max))
    else Nil;

def OneTimeStepScenario batch(Int batch) =
    let List<PairDB> lpdb = batchAux1(batch)
    in map((PairDB db) => Pair(pId(db), tId(db)))(lpdb);

def Scenario scDB() =
    let List<Int> batches = sequence(head(minBatch()), head(maxBatch()))
    // This inserts an empty list if there's no batches that time step; this
    // is correct behavior.
    in map((Int batch_nr) => batch(batch_nr))(batches);

