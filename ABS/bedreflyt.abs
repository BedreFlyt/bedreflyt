module BedreFlyt;
// Initial draft workflow simulator for the BedreFlyt project
// by Einar, Lizeth, Rudi
// October 2024

//------------------------------------------------------------------------------------------------
//--------------------------------- DATATYPES ----------------------------------------------------
//------------------------------------------------------------------------------------------------

//------------------Datatypes for running the simulator------------------------
type TreatmentID = String;
type PatientID = String;

//------------------ Patients -------------------------
data Patient = Person(String perId);

//------------------Treatments------------------
// timestepsAvg is the number of timesteps in average needed for the task
// category is a bed category, according to room distribution
data Task = Task(String id, Int category, Int timestepsAvg, Set<String> dependencies);
type Treatment = List<Task>;

data Bed = Bed (Int catg, String desc);
type BedsCat = Map<Int,String>;


// A "package" is a patient with an associated workflow
data Package = Package(Patient patient, Treatment treatment);

type PendingPacks = List<Package>;  // Pending packages per timestep
type PendingPacksTimeline = List<PendingPacks>;  // Pending packages timeline
//------------------------------------------------------------------------

//-----------Datatypes for input to the simulator-----------------------

//---------------- Treatments - Input from the KB --------------------------------
type Treatments = Map<TreatmentID,Treatment>; // name and associated workflow --> Should be: mapping from diagnosis to treatment

//------------------ Scenarios - Input from the stream of patients ------------------
type OneTimeStepScenario = List<Pair<PatientID,TreatmentID>>;  // stream of (patientId, treatmentId) in one time step
type Scenario = List<OneTimeStepScenario>;  // stream patients per time step (timeline)


//------------------------------------------------------------------------------------------------
//--------------------------------- TASKS & WORKFLOWS -- TREATMENT -------------------------------
//------------------------------------------------------------------------------------------------



// -----------------------------With dependencies ---------------------

// remove task t from all the task dependencies in workflow f
def Treatment removeDependWF(Task t, Treatment f) =
    map((Task hd) => removeDependTask(t, hd))(f);

// Remove task t1 from dependencies of task t2
def Task removeDependTask(Task t1, Task t2)
            = Task(id(t2), category(t2), timestepsAvg(t2), remove(dependencies(t2),id(t1)));

// Check that a task can be done now
def Bool enabled(Task t) = emptySet(dependencies(t));

//------------------------------------------------------------------------------------------------
//--------------------------------Objects that hold bedpost needs per time step -------------------------
//------------------------------------------------------------------------------------------------
interface BedPostNeeds {  // bedpost needs in a time step
    Unit register(Patient p, Int category);
    Unit print();
    Unit printForZ3();
  }

class BedPostNeeds(Int time, BedsCat bc) implements BedPostNeeds {

  Map<Int,List<Patient>> cat = map[];

  Unit init(){
    Int l = length(entries(bc));
    List<Pair<Int,String>> tmpbc = entries(bc);
    Pair<Int,String> tmp = Pair(0,"");
    while (l != 0) {
      tmp = head(tmpbc);
      tmpbc = tail(tmpbc);
      cat = put(cat,fst(tmp),Nil);
      l = l-1;
    }
  }


    Unit register(Patient p, Int i){
        cat = put(cat,i,appendright(lookupDefault(cat,i,Nil),p));
    }

    Unit print(){
        println("\nBedpost needs at time: Time Step " + toString(time));
        foreach(t in entries(cat)){
            println(`Category$fst(t)$---: $length(snd(t))$`);
        }
    }

    Unit printForZ3(){
        foreach(t in entries(cat)){
            foreach (patient in snd(t)) {
                println(perId(patient) + "," + toString(fst(t)));
            }
        }
        println("------");
    }
}

//------------------------------------------------------------------------------------------------
//------------------------------------------------------------------------------------------------

//------------------------------------------------------------------------------------------------
//---------------------------------------- SIMULATION  -------------------------------------------
//------------------------------------------------------------------------------------------------

// Rough idea:
// A "package" is a patient with an associated workflow
// We pick the arriving packages for the time step
// We have two lists of packages to deal with:
// 1) packages where we need to execute the first task of the workflow now (this is done via the OneRunSimulator),
// 2) packages that we need to consider later (packagesForLater)
// When we have executed the first task of a workflow, we push the
// package with the remaining workflow to the packages for later
// for the next time step, we pick the arriving package for the time step and merge it with the remaining packages (packagesForLater)
//
// For each time step we create an object of class BedPostNeeds that holds the bedpost needs.
// These objects are collected in a list "timeline"
// we can then print time step needs from this timeline to access the bedpost needs per time step


interface Simulator {
  List<BedPostNeeds> simulate();
}

class Simulator(Treatments tr, Scenario sc, BedsCat bc) implements Simulator {
    PendingPacks packagesForNow = Nil;

    List<BedPostNeeds> simulate() {
      Int timestepNumber = head(minBatch()); // Starting time step
      List<BedPostNeeds> timeline = Nil; // Holds TimeStep objects
      PrintScenario showSc = new PrintScenario(bc);
      PendingPacks packagesForLater = Nil;
      if(!isEmpty(sc)) {
          // Now we load the incoming packages
          OneTimeStepScenario h = head(sc);
          sc = tail(sc);
          if(h != Nil) {
              packagesForLater = generatePackages(h,tr, Nil);
          }
      }
      while (!isEmpty(packagesForLater)) {
          // Create time step object for current time
          BedPostNeeds timestepNeeds = new BedPostNeeds(timestepNumber,bc); // Object collecting the bedpost needs for current time step
          timeline = Cons(timestepNeeds,timeline);
          // advance to new time step:
          /*
          println("\n------------Processing Time Step " + toString(timestepNumber) + "-----------");
          println("\nRemaining needs from current time step:\n");
          // print scenario
          showSc.inputScenario(packagesForLater);
          showSc.print();
          */
          // simulate one time step: consume the needs for current time step and and collect the needs for later
          packagesForLater = this.simulateOneRun(timestepNumber, packagesForLater, timestepNeeds);
          // print the needs for current time step
          timestepNeeds.printForZ3();
          /*
          timestepNeeds.print();
          println("\nRemaining needs for later:\n");
          // print the remaning needs after finishing the tasks of the current time step
          showSc.inputScenario(packagesForLater);
          showSc.print();
          println("----------End of Current Time Step----------");
          */
          // Finished with packages for the current time step
          timestepNumber = timestepNumber + 1;
          if(!isEmpty(sc)){
            // Now we load the incoming packages for the next time step
            OneTimeStepScenario h = head(sc);
            if(h != Nil){
                packagesForLater = concatenate(packagesForLater,generatePackages(h,tr, Nil));
            }
            sc = tail(sc);
          }
      }
      return timeline;
    }

    // Rough idea:
    // A "package" is a patient with an associated workflow
    // We have two lists of packages to deal with:
    // 1) packages where we need to execute the first task of the workflow now (`packages`),
    // 2) packages that we need to consider later (`packagesForLater`)
    // When we have executed all enabled tasks of a workflow, we push the
    // package with the remaining workflow to the packages for later
    PendingPacks simulateOneRun(Int timestepNumber, PendingPacks packages, BedPostNeeds timestepNeeds){
      // Move packages that we need to deal with the current time step:
        PendingPacks packagesForLater = Nil;
      // Iterate over the packages to process
      foreach (p in packages) {
        // Get workflow from package
        Treatment flow = treatment(p);
        Treatment newFlow = flow;
        // Find tasks to execute -- will currently be only one since
        // we got linear workflows, but there can be parallel tasks
        foreach (t in filter(enabled)(flow)) {
            newFlow = without(flow,t);
            if (timestepsAvg(t) > 1) {
                newFlow = Cons(Task(id(t), category(t), timestepsAvg(t) - 1, dependencies(t)), newFlow);
            } else {
                newFlow = removeDependWF(t,newFlow);
            }
            // Register resource needs of the task
            timestepNeeds.register(patient(p),category(t));
        }
        if (!isEmpty(newFlow)){
            // Create package with remaining workflow
            Package newPackage = Package(patient(p),newFlow);
            // Push new package on packages for later
            packagesForLater = appendright(packagesForLater,newPackage);
        }
      }
    return packagesForLater;
  }

}
//------------------------------------------------------------------------------------------------
//------------------------------------------------------------------------------------------------

//------------------------------------------------------------------------------------------------
//---------------------------------------- SCENARIOS  --------------------------------------------
//------------------------------------------------------------------------------------------------

interface PrintScenario { // printing scenario per time step
  Unit inputScenario(PendingPacks sc);
  Unit print();
}

class PrintScenario(BedsCat bc) implements PrintScenario {
  PendingPacks scenario = Nil;

  Unit inputScenario(PendingPacks sc) {scenario = sc;}

  Unit print() {
      foreach (p in scenario) {
          println(perId(patient(p)) + " needs");
          Treatment w = treatment(p);
          foreach (t in w) {
              println(`- $lookupDefault(bc,category(t),"")$ for $timestepsAvg(t)$ timesteps`);
          }
      }
  }

}

def PendingPacks generatePackages(OneTimeStepScenario odsc,Treatments tr, PendingPacks p) =
  case odsc {
    Nil => p;
    Cons(hd,tl) => generatePackages(tl,tr, appendright(p,Package(Person(fst(hd)),lookupDefault(tr,snd(hd),Nil))))} ;

