module BedreFlyt;
// Initial draft workflow simulator for the BedreFlyt project
// by Einar, Lizeth, Rudi
// October 2024

//------------------------------------------------------------------------------------------------
//--------------------------------- DATATYPES ----------------------------------------------------
//------------------------------------------------------------------------------------------------
//------------------ Patients -------------------------
data Patient = Person(String perId);

//------------------Treatments------------------
// days is the number of days needed for the task
// category is a bed category,
// 1 -- Sengepost
// 2 -- Intermediaer
// 3 -- Overvaakning
// 4 -- Surgery room
data Task = EmptyTask | Task(String id, Int category, Int days, Set<String> dependencies);
type WF = List<Task>;
type Treatments = Map<String,WF>;

// A "package" is a patient with an associated workflow
data Package = Package(Patient patient, WF treatment);

type PendingPacks = List<Package>;  // Pending packages per day
type PendingPacksTimeline = List<PendingPacks>;  // Pending packages timeline

//------------------ Scenarios ------------------
type OneDayScenario = List<Pair<String,String>>;  // stream of (patientId, treatmentId) in one day
type Scenario = List<OneDayScenario>;  // stream patients per day (timeline)


//------------------------------------------------------------------------------------------------
//--------------------------------- TASKS & WORKFLOWS -- TREATMENT -------------------------------
//------------------------------------------------------------------------------------------------
// remove task t from all the task dependencies in workflow f
def WF removeDependWF(Task t, WF f) =
    case f {
    Nil => Nil;
    Cons(hd,tl) => Cons(removeDependTask(t,hd),removeDependWF(t,tl)); } ;

// Remove task t1 from dependencies of task t2
def Task removeDependTask(Task t1, Task t2)
            = Task(id(t2), category(t2), days(t2), remove(dependencies(t2),id(t1)));

		// Check that a task can be done now
def Bool enabled(Task t) = emptySet(dependencies(t));

//------------------------------------------------------------------------------------------------
//--------------------------------Objects that hold bedpost needs per day -------------------------
//------------------------------------------------------------------------------------------------
interface BedPostNeeds {  // bedpost needs in a day
    Unit register(Patient p, Int category);
    Unit print(); }

class BedPostNeeds(Int i) implements BedPostNeeds {
    List<Patient> cat1 = Nil;
    List<Patient> cat2 = Nil;
    List<Patient> cat3 = Nil;
		List<Patient> cat4 = Nil;

    Unit register(Patient p, Int i){
			switch (i)
	    {
				1 => cat1 = Cons(p,cat1);
				2 => cat2 = Cons(p,cat2);
				3 => cat3 = Cons(p,cat3);
				4 => cat4 = Cons(p,cat4);
				_ => skip;
	    }
    }

    Unit print(){
			println("\nBedpost needs at time: Day " + toString(i));
			println("Category Sengepost---: " + toString(length(cat1)));
			println("Category Intermediaer: " + toString(length(cat2)));
			println("Category Overvaakning: " + toString(length(cat3)));
			println("Category Surgery-----: " + toString(length(cat4)));
    }
}

//------------------------------------------------------------------------------------------------
//------------------------------------------------------------------------------------------------

//------------------------------------------------------------------------------------------------
//---------------------------------------- SIMULATION  -------------------------------------------
//------------------------------------------------------------------------------------------------

// Rough idea:
// A "package" is a patient with an associated workflow
// We pick the arriving package for the day
// We have two lists of packages to deal with:
// 1) packages where we need to execute the first task of the workflow now (this is done via the OneRunSimulator),
// 2) packages that we need to consider later (packagesForLater)
// When we have executed the first task of a workflow, we push the
// package with the remaining workflow to the packages for later
// for the next day, we pick the arriving package for the day and merge it with the remaining packages (packagesForLater)
//
// For each day we create an object of class BedPostNeeds that holds the bedpost needs.
// These objects are collected in a list "timeline"
// we can then print day needs from this timeline to access the bedpost needs per day


interface Simulator {
  PendingPacks simulateOneRun(Int dayNumber, PendingPacks packagesForLater, BedPostNeeds dayNeeds);
  List<BedPostNeeds> simulate();
}

class Simulator(Treatments tr, Scenario sc) implements Simulator {
    PendingPacks packagesForNow = Nil;

    List<BedPostNeeds> simulate(){
      Int dayNumber = 1; // Starting day
      List<BedPostNeeds> timeline = Nil; // Holds Day objects
      BedPostNeeds dayNeeds;
      PrintScenario showSc = new PrintScenario();
      PendingPacks packagesForLater = Nil;
      if(!isEmpty(sc)){
        // Now we load the incoming packages
        packagesForLater = concatenate(packagesForLater,generatePackages(head(sc),tr, Nil));
        sc = tail(sc);
      }
      while (!isEmpty(packagesForLater)) {
          // Create Day object for today
          dayNeeds = new BedPostNeeds(dayNumber); // Object collecting the bedpost needs for today
          timeline = Cons(dayNeeds,timeline);
          // advance to new day:
          println("\n------------Processing Day " + toString(dayNumber) + "-----------");
          println("\nRemaining needs from Today:\n");
          // print scenario
          showSc.inputScenario(packagesForLater);
          showSc.print();
          // simualte: consume the needs for today and and collect the needs for later
          packagesForLater = this.simulateOneRun(dayNumber, packagesForLater, dayNeeds);
          // print the needs for today
          dayNeeds.print();
          println("\nRemaining needs for later:\n");
          // print the remaning needs after finishing the tasks of the day
          showSc.inputScenario(packagesForLater);
          showSc.print();
          println("----------End of Day----------");
          // Finished with packages for today
          dayNumber = dayNumber + 1;
          if(!isEmpty(sc)){
            // Now we load the incoming packages for the next day
            packagesForLater = concatenate(packagesForLater,generatePackages(head(sc),tr, Nil));
            sc = tail(sc);
          }
      }
      return timeline;
    }

    // Rough idea:
    // A "package" is a patient with an associated workflow
    // We have two lists of packages to deal with:
    // 1) packages where we need to execute the first task of the workflow now (packagesForNow),
    // 2) packages that we need to consider later (packagesForLater)
    // When we have executed the first task of a workflow, we push the
    // package with the remaining workflow to the packages for later

    PendingPacks simulateOneRun(Int dayNumber, PendingPacks packagesForLater, BedPostNeeds dayNeeds){
      // Move packages that we need to deal with today:
      packagesForNow = packagesForLater;
      packagesForLater = Nil;
      // Iterate over the packages to process
      while (!isEmpty(packagesForNow)){
        // Take the first package
        Package p = head(packagesForNow);
        packagesForNow = tail(packagesForNow);
        // Get workflow from package
        WF flow = treatment(p);
        // Find task to execute
        Task t = head(filter(enabled)(flow));
        WF newFlow = Nil;
        if (days(t) == 1){
             newFlow = without(flow,t);}
        else {
             Task t2 = Task(id(t), category(t), days(t)-1, dependencies(t));
             newFlow = Cons(t2,without(flow,t));

        }
        // Register resource needs of the task
        dayNeeds.register(patient(p),category(t));
        // More stuff to do in remaining flow?
        if (!isEmpty(newFlow)){
            // Create package with remaining workflow
            WF remaining = removeDependWF(t,newFlow);
            Package newPackage = Package(patient(p),remaining);
            // Push new package on packages for later
            packagesForLater = appendright(packagesForLater,newPackage);

        }
     }
    return packagesForLater;
  }

}
//------------------------------------------------------------------------------------------------
//------------------------------------------------------------------------------------------------

//------------------------------------------------------------------------------------------------
//---------------------------------------- SCENARIOS  --------------------------------------------
//------------------------------------------------------------------------------------------------

interface PrintScenario { // printing scenario per day
  Unit inputScenario(PendingPacks sc);
  Unit print();
}

class PrintScenario() implements PrintScenario {
  PendingPacks scenario = Nil;

  Unit inputScenario(PendingPacks sc) {scenario = sc;}

  Unit print(){
    while(!isEmpty(scenario)){
      Package p = head(scenario);
      scenario = tail(scenario);
      println(perId(patient(p)) + " needs");
      WF w = treatment(p);
      foreach (t in w) {
        switch (category(t))
        {
          1 => println("- Sengepost for " + toString(days(t)) + " days");
          2 => println("- Intermediaer for " + toString(days(t)) + " days");
          3 => println("- Overvaakning for " + toString(days(t)) + " days");
          4 => println("- Surgery room for " + toString(days(t)) + " days");
        }
      }
    }
  }

}

def PendingPacks generatePackages(OneDayScenario odsc,Treatments tr, PendingPacks p) =
  case odsc {
    Nil => p;
    Cons(hd,tl) => generatePackages(tl,tr, appendright(p,Package(Person(fst(hd)),lookupDefault(tr,snd(hd),Nil))))} ;

